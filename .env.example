# ULTSNOWER / SNOW Merchant Portal Server local development config.
# Copy to `.env` or set these values in your shell before running.
# Do not commit real production secrets.

MERCHANT_DB_PATH=data/merchant.sqlite

BRIDGE_BASE_URL=http://127.0.0.1:8010
BRIDGE_MERCHANT_KEY=mk_test
BRIDGE_MERCHANT_SECRET=dev_bridge_merchant_secret
BRIDGE_API_PREFIX=/api/external/v1
BRIDGE_AUTH_HEADER_PREFIX=External

MERCHANT_REF_SECRET=dev_merchant_ref_secret_change_me
MERCHANT_SESSION_TTL_SECONDS=86400
MERCHANT_ENABLE_BACKGROUND_WORKERS=0
MERCHANT_INTERNAL_WORKER_TOKEN=

MERCHANT_HOST=127.0.0.1
MERCHANT_PORT=8020
MERCHANT_ADMIN_USERNAME=admin
MERCHANT_ADMIN_PASSWORD=change_me_before_production
MERCHANT_REQUIRE_BRIDGE_SETUP=0

# Optional live integration tests against a sibling/current SNOWSERVER checkout.
RUN_LIVE_SNOWSERVER_TESTS=0
SNOWSERVER_REPO=../SNOWSERVER
